[Unit]
Description=GreyHourRP RUM telemetry rollup
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/greyhourrp-automation
WorkingDirectory=/opt/greyhourrp
ExecStart=/opt/greyhourrp/scripts/systemd/run-with-alert.sh rum-rollup /opt/greyhourrp/scripts/rum-rollup.sh
