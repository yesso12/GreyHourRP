[Unit]
Description=GreyHourRP backup verification and restore test
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/greyhourrp-automation
WorkingDirectory=/opt/greyhourrp
ExecStart=/opt/greyhourrp/scripts/systemd/run-with-alert.sh backup-verify /opt/greyhourrp/scripts/backup-verify.sh
