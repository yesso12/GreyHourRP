[Unit]
Description=GreyHourRP Secrets Rotation
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/greyhourrp-automation
WorkingDirectory=/opt/greyhourrp
ExecStart=/opt/greyhourrp/scripts/systemd/run-with-alert.sh secrets-rotation /opt/greyhourrp/scripts/systemd/rotate-secrets.sh

[Install]
WantedBy=multi-user.target
