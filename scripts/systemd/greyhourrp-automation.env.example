# Optional overrides consumed by GreyHourRP automation services.
# Copy to: /etc/default/greyhourrp-automation

# Automation notifications
AUTOMATION_ALERTS_ENABLED=true
AUTOMATION_ALERT_WEBHOOK_URL=
AUTOMATION_ALERT_MAX_LINES=25
AUTOMATION_ALERT_MAX_CHARS=3500
AUTOMATION_ALERT_STATE_DIR=/var/lib/greyhourrp-automation-alerts
AUTOMATION_ALERT_WEBHOOK_DISABLE_AFTER_FAILS=3
AUTOMATION_ALERT_WEBHOOK_DISABLE_SECONDS=3600
AUTOMATION_ALERT_WEBHOOK_PROBE_INTERVAL_SECONDS=300
AUTOMATION_ALERT_CHANNEL_ID=
AUTOMATION_DISCORD_TOKEN=
AUTOMATION_DISCORD_TOKEN_FILE=/opt/greyhourrp-discord-bot/.env
AUTOMATION_ALERT_CHANNEL_KEY=LOG_CHANNEL_ID

# Self-heal target/static deploy
STATIC_TARGET=/var/www/greyhourrp
BOT_APP_DIR=/opt/greyhourrp-discord-bot
BOT_SERVICE=greyhourrp-discord-bot
SELF_HEAL_DEPLOY_BOT=true

# Health check toggles
CHECK_ADMIN_API_SERVICE=true
CHECK_DISCORD_BOT_SERVICE=true
RUN_BOT_SMOKE_CHECK=true
ADMIN_API_SERVICE_NAME=greyhourrp-admin-api
DISCORD_BOT_SERVICE_NAME=greyhourrp-discord-bot

# Backup automation
CONTENT_ROOT=/var/www/greyhourrp/content
BOT_DATA_ROOT=/opt/greyhourrp-discord-bot/data
BACKUP_ROOT=/var/backups/greyhourrp
RETENTION_DAYS=14

# Restore drill automation
RESTORE_DRILL_ROOT=/tmp/greyhourrp-restore-drill
RESTORE_DRILL_KEEP_LATEST=3

# Secrets rotation automation
ADMIN_API_ENV_PATH=/etc/greyhourrp-admin-api.env
BOT_ENV_PATHS=/opt/greyhourrp/discord-bot/.env:/opt/greyhourrp-discord-bot/.env
SECRET_ROTATE_MIN_LENGTH=40
SECRET_ROTATE_DRY_RUN=false

# Service guard automation
WATCH_SERVICES=greyhourrp-admin-api greyhourrp-discord-bot
RESTART_COOLDOWN_SECONDS=300
SERVICE_GUARD_STATE_DIR=/var/lib/greyhourrp-service-guard

# Integrity automation
QUARANTINE_ROOT=/var/backups/greyhourrp/quarantine
ENABLE_AUTO_RESTORE_ON_CORRUPTION=true
CONTENT_SCAN_MAXDEPTH=1
