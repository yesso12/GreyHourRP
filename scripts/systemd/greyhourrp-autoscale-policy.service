[Unit]
Description=GreyHourRP autoscale policy decision engine
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/greyhourrp-automation
WorkingDirectory=/opt/greyhourrp
ExecStart=/opt/greyhourrp/scripts/systemd/run-with-alert.sh autoscale-policy /opt/greyhourrp/scripts/autoscale-policy.sh
